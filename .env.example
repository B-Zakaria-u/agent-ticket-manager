# ── Google Gemini (REQUIRED if LLM_PROVIDER=google) ──────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# ── GitHub (REQUIRED) ────────────────────────────────────────────────────────
# Create a PAT with repo + issues scopes:
# https://github.com/settings/tokens/new
GITHUB_TOKEN=your_github_pat_here
GITHUB_REPOSITORY=your-org/your-repo       # e.g. B-Zakaria-u/AAI-mock-repo

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: google (default) | groq | lmstudio
LLM_PROVIDER=google

# ── LM Studio (Local LLM) ────────────────────────────────────────────────────

# ────── Model tested ───────────────────────────────────                 ──────── Review ───────────────────────────────
#       qwen/qwen3-4b                                                       - Not Available yet
#   qwen3.5-2b-claude-4.6-opus-reasoning-distilled@q4_k_m                   - Horrible at reasoning
#       qwen/qwen3-4b-2507                                                  - Not Available yet
# 

LMSTUDIO_BASE_URL=http://127.0.0.1:11434/v1
LMSTUDIO_MODEL=qwen/qwen3-4b-2507

# ── Groq (REQUIRED if LLM_PROVIDER=groq) ─────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile        # e.g. llama-3.3-70b-versatile, mixtral-8x7b-32768

MODEL_NAME=your_model_name                 # used when LLM_PROVIDER=google (e.g. gemini-2.0-flash)

# __ Max token limit for all llm (Default at 8192 for online llms)_____________
MAX_TOKEN=your_max_token_limit_here

# The app automatically resolves its own GitHub username from the token.

# Interfacing the whole LLM config with MODEL_PROFILE variable present inside the src/config/llm.py
# Possible values : LOW(2B to 4B) - STANDARD(7B to 14B) - HIGH(27 to 30B) - CUSTOM
MODEL_PROFILE=HIGH

# Add custom values here
MAX_CONTEXT=12000
MAX_TOOL_OUT=6000
MAX_HISTORY=20
MAX_FILES=80
MAX_SPEC=6000
MAX_TEST_OUT=3000
SYSTEM_VERBOSE=true


# ── LangSmith (OPTIONAL — observability only) ────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_api_key_here
# LANGCHAIN_PROJECT=ai-dev-system

# Host ip of the project :(Default at 0.0.0.0 for local host) 
IP_ADDRESS = ip_address_of_your_project_here

# Domain name, for later definition - Current value will be null
DOMAIN_NAME = your_domain_name_here

